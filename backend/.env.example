# ── App ───────────────────────────────────────────────
NODE_ENV=development
APP_NAME=IMS
PORT=4000
API_BASE_PATH=/api/v1
FRONTEND_URL=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────
DATABASE_URL=postgresql://ims_user:change_me@localhost:5432/ims
DB_POOL_MAX=10

# ── Auth / JWT ────────────────────────────────────────
JWT_ACCESS_SECRET=replace_with_long_random_string
JWT_REFRESH_SECRET=replace_with_another_long_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=7d
PASSWORD_SALT_ROUNDS=12

# ── Security ──────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=120

# ── Business defaults ─────────────────────────────────
DEFAULT_BASE_CURRENCY=USD
WRITE_OFF_APPROVAL_THRESHOLD=500
ALLOW_NEGATIVE_STOCK=false

# ── Observability ─────────────────────────────────────
LOG_LEVEL=info
